{
  "name": "tokscale-floating-monitor",
  "description": "Floating tray monitor for tokscale token usage",
  "author": "Local User",
  "license": "MIT",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "prepare:tokscale": "node scripts/prepare-tokscale.cjs",
    "postinstall": "npm run prepare:tokscale",
    "dev:web": "vite",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "dev": "concurrently -k \"npm run dev:web\" \"npm run dev:electron\"",
    "build:web": "tsc -b && vite build",
    "build": "npm run build:installer",
    "build:portable": "npm run prepare:tokscale && npm run build:web && electron-builder --win portable",
    "build:installer": "npm run prepare:tokscale && npm run build:web && set HTTP_PROXY=& set HTTPS_PROXY=& set ALL_PROXY=& electron-builder --win nsis",
    "pack": "npm run prepare:tokscale && npm run build:web && electron-builder --dir",
    "lint": "eslint .",
    "preview": "vite preview",
    "version:patch": "node scripts/version-bump.js patch",
    "version:minor": "node scripts/version-bump.js minor",
    "version:major": "node scripts/version-bump.js major"
  },
  "dependencies": {
    "@tokscale/cli-win32-x64-msvc": "2.0.22",
    "electron-updater": "^6.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.tokscale.floatingmonitor",
    "productName": "Tokscale Floating Monitor",
    "electronDist": "node_modules/electron/dist",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/logo.png",
        "to": "logo.png"
      },
      {
        "from": "build/tokscale.exe",
        "to": "tokscale.exe"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false,
      "icon": "dist/logo.png",
      "artifactName": "${productName}-${version}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh",
      "unicode": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
